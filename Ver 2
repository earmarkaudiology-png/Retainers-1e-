                    menuBtn('Cancel', cancelCmd, CONFIG.sectionColors.manage.bg, CONFIG.sectionColors.manage.border, 80) +
                '</div>'
            ), msg.who, msg.playerid);
            return;
        }

        delete state[STATE].candidates[candidate.id];
        send(box('Candidate Deleted', line('Removed', esc(candidate.name) + ' [' + esc(candidate.id) + ']')), msg.who, msg.playerid);
    }

