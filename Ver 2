    function handleReport(msg, args) {
        var entries = getRetainerRosterEntries();
        var employer, grouped, keys, sections;

        if (args.pc || args.employer) {
            employer = getCharacterByRef(args.pc || args.employer);
            if (!employer) {
                send('Employer not found.', msg.who, msg.playerid);
                return;
            }
            entries = _.filter(entries, function (e) { return entryAttr(e, ATTR.EMPLOYER_ID) === employer.id; });
        } else if (!playerIsGM(msg.playerid) && !parseBool(args.all, false)) {
            entries = _.filter(entries, function (e) { return entryAttr(e, ATTR.EMPLOYER_PLAYER_ID) === msg.playerid; });
        }

        if (!entries.length) {
            sendPublic(box('Retainer Report', 'No retainers found.'));
            return;
        }

        grouped = {};
        _.each(entries, function (e) {
            var employerName = entryAttr(e, ATTR.EMPLOYER_NAME) || 'Unassigned';
            if (!grouped[employerName]) grouped[employerName] = [];
            grouped[employerName].push(e);
        });

        keys = _.keys(grouped).sort();

        sections = _.map(keys, function (employerName) {
            var group = grouped[employerName];
            var employerId = entryAttr(group[0], ATTR.EMPLOYER_ID);
            var employerChar = getCharacterByRef(employerId);
            var maxHenchmen = employerChar ? getMaximumHenchmen(employerChar) : 0;
            var currentHenchmen = _.filter(group, function (e) {
                return normalizeText(entryAttr(e, ATTR.RETAINER_TYPE)) === 'henchman' && normalizeText(entryAttr(e, ATTR.STATUS)) === 'active';
            }).length;

            var header = '<div style="margin-bottom:2px;"><b>' + esc(employerName) + '</b> — player: ' + esc(getDisplayName(entryAttr(group[0], ATTR.EMPLOYER_PLAYER_ID)));
            if (maxHenchmen > 0) header += ' — henchmen: ' + currentHenchmen + '/' + maxHenchmen;
            header += '</div>';

            var items = _.map(_.sortBy(group, function (e) {
                return (e.character.get('name') || '').toLowerCase();
            }), function (e) {
                var cd = entryAttr(e, ATTR.CONTRACT_DAYS);
                var pp = entryAttr(e, ATTR.PAY_PERIOD);
                var contractPay = entryAttr(e, ATTR.CONTRACT_PAY_GP);
                return '<li><b>' + esc(e.character.get('name')) + '</b> — ' +
                    esc(entryAttr(e, ATTR.RETAINER_TYPE)) +
                    (entryAttr(e, ATTR.RETAINER_SUBTYPE) ? ' (' + esc(entryAttr(e, ATTR.RETAINER_SUBTYPE)) + ')' : '') +
                    ' — status: ' + esc(entryAttr(e, ATTR.STATUS)) +
                    ' — wage: ' + esc(formatWage(entryAttr(e, ATTR.DAILY_WAGE_SP), entryAttr(e, ATTR.MONTHLY_WAGE_GP))) +
                    (contractPay && contractPay !== '0' ? ' — contract pay due: ' + esc(contractPay) + ' gp' : '') +
                    ' — share: ' + esc(entryAttr(e, ATTR.TREASURE_SHARE_PCT)) + '%' +
                    ' — loyalty: ' + esc(entryAttr(e, ATTR.LOYALTY_CURRENT)) +
                    (cd && String(cd) !== '0' ? ' — ' + esc(cd) + ' day(s)' : '') +
                    (pp ? ' (' + esc(pp) + ')' : '') +
                    ' — xp: ' + esc(entryAttr(e, ATTR.RETAINER_XP_MODE) || defaultXpModeForType(entryAttr(e, ATTR.RETAINER_TYPE))) +
                    (entryAttr(e, ATTR.ASSIGNMENT) ? ' — assignment: ' + esc(entryAttr(e, ATTR.ASSIGNMENT)) : '') +
                    '</li>';
            }).join('');

            return '<div style="margin-bottom:8px;">' + header + '<ul style="margin:4px 0 0 18px;">' + items + '</ul></div>';
        }).join('');

        sendPublic(box('Retainer Report', sections));
    }

