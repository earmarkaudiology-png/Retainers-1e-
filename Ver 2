    }

    function coinAttrs() {
        return [
            { attr: CONFIG.sheetAttrs.gp, key: 'gp', cp: 100 },
            { attr: CONFIG.sheetAttrs.sp, key: 'sp', cp: 10 },
            { attr: CONFIG.sheetAttrs.cp, key: 'cp', cp: 1 }
        ];
    }

    function getCoinBundle(characterId) {
        var out = { gp: 0, sp: 0, cp: 0 };
        _.each(coinAttrs(), function (c) {
            out[c.key] = parseIntSafe(getAttr(characterId, c.attr), 0) || 0;
        });
        return out;
    }

    function totalCpFromBundle(bundle) {
        var total = 0;
        _.each(coinAttrs(), function (c) {
            total += (bundle[c.key] || 0) * c.cp;
        });
        return total;
    }

    function bundleFromCp(totalCp) {
        var remaining = Math.max(0, Math.round(totalCp));
        var out = { gp: 0, sp: 0, cp: 0 };
        _.each(coinAttrs(), function (c) {
            out[c.key] = Math.floor(remaining / c.cp);
            remaining = remaining % c.cp;
        });
        return out;
    }

    function setCoinBundle(characterId, bundle) {
        setAttr(characterId, CONFIG.sheetAttrs.gp, bundle.gp || 0);
        setAttr(characterId, CONFIG.sheetAttrs.sp, bundle.sp || 0);
        setAttr(characterId, CONFIG.sheetAttrs.cp, bundle.cp || 0);
    }

    function formatCoinBundle(bundle) {
        return 'GP: ' + (bundle.gp || 0) +
            ', SP: ' + (bundle.sp || 0) +
            ', CP: ' + (bundle.cp || 0);
    }

    function formatCpAsCoins(cp) {
        return formatCoinBundle(bundleFromCp(cp));
    }

    function bundleFromSingleCoin(coinKey, amount) {
        var out = { gp: 0, sp: 0, cp: 0 };
        out[coinKey] = Math.max(0, parseIntSafe(amount, 0) || 0);
        return out;
    }

    function deductCoins(character, amountCp) {
        var before = getCoinBundle(character.id);
        var total = totalCpFromBundle(before);

        if (amountCp <= 0) {
            return {
                ok: true,
                before: before,
                after: before,
                amountCp: 0
            };
        }

        if (total < amountCp) {
            return {
                ok: false,
                before: before,
                after: before,
                amountCp: amountCp
            };
        }

        var after = bundleFromCp(total - amountCp);
        setCoinBundle(character.id, after);

        return {
            ok: true,
            before: before,
            after: after,
            amountCp: amountCp
        };
    }


    function addCoins(character, amountCp) {
        var before = getCoinBundle(character.id);
        var total = totalCpFromBundle(before);
        var after = bundleFromCp(total + Math.max(0, Math.round(amountCp || 0)));

        setCoinBundle(character.id, after);

        return {
            ok: true,
            before: before,
            after: after,
            amountCp: Math.max(0, Math.round(amountCp || 0))
        };
    }

