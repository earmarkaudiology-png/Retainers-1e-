        depositResult = addCoins(retainer, pay.totalCp);
        setAttr(retainer.id, ATTR.CONTRACT_PAY_GP, 0);

        body = line('Employer', esc(employer.get('name'))) +
            line('Retainer', esc(retainer.get('name'))) +
            line('Paid', formatCpAsCoins(pay.totalCp)) +
            line('Employer before', formatCoinBundle(paymentResult.before)) +
            line('Employer after', formatCoinBundle(paymentResult.after)) +
