        var hirelingKeys = _.map(getStandardMarketEntries('hireling'), function (entry) {
            return subtypeKeyForEntry(entry);
        });
        var expertKeys = _.chain(getStandardMarketEntries('expert'))
            .filter(function (entry) {
                var key = subtypeKeyForEntry(entry);

                if ((parseIntSafe(population, 0) || 0) > 500) return true;
                if (isAlwaysAvailableSmallTownExpertKey(key)) return true;
                return pctRoll() <= 20;
            })
            .map(function (entry) {
                return subtypeKeyForEntry(entry);
            })
            .value();

        return {
            enabled: true,
            population: parseIntSafe(population, 0) || 0,
            hirelingKeys: hirelingKeys,
            expertKeys: expertKeys
        };
