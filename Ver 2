    function handleSeek(msg, args) {
        var employer = getEmployerCharacter(msg, args);
        var population;
        var responseRate = CONFIG.defaultResponseRatePct;
        var incidence = CONFIG.seekIncidence;
        var useNotices, useCrier, useAgents, taverns, tavernFee;
        var noticesEff = 0, crierEff = 0, agentsEff = 0, tavernEff = 0;
        var tavernRaw = 0, tavernPenalty = 0;
        var methodsUsed = 0, overlapPenalty = 0;
        var totalEligible = 0, applicants = 0;
        var coverageRaw = 0, finalCoverage = 0;
        var cost = 0, responseWindow = 0;
        var raceBands, generated = [], i, feeSteps, j, estEff;
        var perDay = [], basePerDay = 0, remainder = 0, k, body;
        var marketOptionsData;
        var dayLines = [];
        var details = [];
        var paymentResult;

        if (!requireControl(msg, employer, 'employer character')) return;

        population = parseIntSafe(args.population, 0) || 0;
        if (!population) {
            send('Use --population|<number>.', msg.who, msg.playerid);
            return;
        }

        useNotices = parseBool(args.notices, false);
        useCrier = parseBool(args.crier, false);
        useAgents = parseBool(args.agents, false);
        taverns = Math.max(0, Math.min(10, parseIntSafe(args.taverns, 0) || 0));
        tavernFee = Math.max(10, Math.min(50, parseMoney(args.tavernfee, 20)));

        if (useNotices) {
            noticesEff = randomInt(10, 40);
            cost += 50;
            methodsUsed += 1;
            details.push('Posting notices: ' + noticesEff + '% for 50 gp');
        }

        if (useCrier) {
            crierEff = randomInt(1, 10);
            cost += 10;
            methodsUsed += 1;
            details.push('Hiring a crier: ' + crierEff + '% for 10 gp');
        }

        if (useAgents) {
            agentsEff = randomInt(20, 50);
            cost += 300;
            methodsUsed += 1;
            details.push('Hiring agents: ' + agentsEff + '% for 300 gp');
        }

        if (taverns > 0) {
            methodsUsed += 1;
            feeSteps = Math.max(1, Math.min(5, Math.floor(tavernFee / 10)));

            for (i = 0; i < taverns; i++) {
                estEff = 0;
                for (j = 0; j < feeSteps; j++) estEff += randomInt(1, 4);
                tavernRaw += estEff;
            }

            tavernPenalty = Math.max(0, taverns - 1);
            tavernEff = Math.max(0, tavernRaw - tavernPenalty);
            cost += taverns * tavernFee;

            details.push('Inns/taverns: raw ' + tavernRaw + '% - ' + tavernPenalty + '% overlap = ' +
                tavernEff + '% for ' + taverns + ' establishment(s) at ' + tavernFee +
                ' gp each (' + (taverns * tavernFee) + ' gp total)');
        }

        paymentResult = deductCoins(employer, gpToCp(cost));
        if (!paymentResult.ok) {
            send(box(
                'Recruitment Failed',
                line('Employer', esc(employer.get('name'))) +
                line('Recruitment cost', formatCpAsCoins(gpToCp(cost))) +
                line('Current coins', formatCoinBundle(paymentResult.before)) +
                '<div style="color:#ff6666;font-weight:bold;margin-top:6px;">Not enough coin on the employer sheet.</div>'
            ), msg.who, msg.playerid);
            return;
        }

        coverageRaw = noticesEff + crierEff + agentsEff + tavernEff;
        overlapPenalty = Math.max(0, (methodsUsed - 1) * 5);
        finalCoverage = Math.max(0, coverageRaw - overlapPenalty);

        totalEligible = Math.max(0, Math.floor(population / incidence));
        applicants = Math.max(0, Math.round(totalEligible * (finalCoverage / 100) * (responseRate / 100)));

        responseWindow = responseWindowFromPopulation(population);
        basePerDay = responseWindow > 0 ? Math.floor(applicants / responseWindow) : 0;
        remainder = responseWindow > 0 ? (applicants % responseWindow) : 0;

        for (k = 0; k < responseWindow; k++) {
            perDay[k] = basePerDay + (k < remainder ? 1 : 0);
        }

        raceBands = normalizeRaceDistribution(parseDistribution(args.races));
        for (i = 0; i < applicants; i++) {
            generated.push(buildCandidate(employer, getEmployerPlayerId(employer, msg.playerid), raceBands));
        }

        for (k = 0; k < perDay.length; k++) {
            dayLines.push('<li>Day ' + (k + 1) + ': ' + perDay[k] + '</li>');
        }

        marketOptionsData = generateMarketOptionsData(population);
        if (population <= 500) {
            details.push('Small population expert limit: experts other than Blacksmith and Jeweler-Gemcutter appear only on a 20% chance.');
        }
        if (population >= 5001 && population <= 8000) {
            details.push('Population 5001-8000 uses a 1d10 day response window.');
        }
        if (employer && employer.id) setEmployerMarketOptions(employer.id, marketOptionsData);

        body = '' +
            line('Employer', esc(employer.get('name'))) +
            line('Population', population) +
            line('Eligible prospects', totalEligible + ' (1 in 1000 baseline)') +
            line('Coverage before combination penalty', coverageRaw + '%') +
            line('Combination penalty', '-' + overlapPenalty + '%') +
            line('Final coverage', finalCoverage + '%') +
            line('Applicant response rate', '65% fixed') +
            line('Total applicants', applicants) +
            line('Response window', responseWindow + ' day(s), rolled by API from population size') +
            line('Recruitment cost', formatCpAsCoins(gpToCp(cost))) +
            line('Coins before', formatCoinBundle(paymentResult.before)) +
            line('Coins after', formatCoinBundle(paymentResult.after)) +
            '<hr style="border-color:#555;" /><div><b>Method details</b><ul style="margin:4px 0 0 18px;">' +
            _.map(details, function (d) { return '<li>' + esc(d) + '</li>'; }).join('') +
            '</ul></div>' +
            '<hr style="border-color:#555;" /><div><b>Applicants by day</b><ul style="margin:4px 0 0 18px;">' + dayLines.join('') + '</ul></div>';

        if (generated.length) {
            body += '<hr style="border-color:#555;" /><div><b>Henchman candidates created</b>' +
                '<div style="margin:6px 0 8px 0;">' +
                    removeCandidatesBtn(buildClearCandidatesCommand({ pc: employer.id }), 118) +
                '</div><ul style="margin:4px 0 0 18px;">' +
                _.map(generated, function (c) { return renderCandidateEntry(msg, c); }).join('') + '</ul></div>';
        }

        body += '<hr style="border-color:#555;" /><div><b>Market hireling and expert options</b></div>' + buildStandardMarketOptionsHtml(employer);

        body += '<hr style="border-color:#555;" />' + buildRecruitmentHirelingHtml(employer);

        send(box('Retainer Market Search', body), msg.who, msg.playerid);
    }

