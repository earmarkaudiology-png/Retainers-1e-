    function parseArgs(content) {
        var args = {};
        var parts = String(content || '').split(/\s+--/);
        var i, p, idx, key, val;

        parts.shift();

        for (i = 0; i < parts.length; i++) {
            p = parts[i];
            idx = p.indexOf('|');
            if (idx === -1) continue;
            key = p.slice(0, idx).replace(/^\s+|\s+$/g, '').toLowerCase();
            val = p.slice(idx + 1).replace(/^\s+|\s+$/g, '');

            if ((val.charAt(0) === '"' && val.charAt(val.length - 1) === '"') ||
                (val.charAt(0) === "'" && val.charAt(val.length - 1) === "'")) {
                val = val.slice(1, -1);
            }
            args[key] = val;
        }
        return args;
    }

    function parseCsvList(value) {
        if (!value) return [];
        return String(value).split(',').map(function (s) { return s.trim(); }).filter(Boolean);
    }

    function parseDistribution(value) {
        var result = [];
        _.each(parseCsvList(value), function (entry) {
            var parts = entry.split(':');
            if (parts.length === 2) {
                result.push({ race: parts[0].trim(), pct: parseNumber(parts[1], 0) });
            }
        });
        return result;
    }

    function splitControlledBy(controlledby) {
        if (!controlledby) return [];
        return String(controlledby).split(',').map(function (s) { return s.trim(); }).filter(Boolean);
    }

    function firstControlledPlayerId(character) {
        if (!character) return '';
        var controlled = _.filter(splitControlledBy(character.get('controlledby')), function (id) {
            return id && id !== 'all';
        });
        return controlled.length ? controlled[0] : '';
    }

    function getEmployerPlayerId(employer, fallbackPlayerId) {
        var controlled = firstControlledPlayerId(employer);
        return controlled || fallbackPlayerId || '';
    }

    function findPlayer(playerid) {
        return getObj('player', playerid);
    }

    function getDisplayName(playerid) {
        var p = findPlayer(playerid);
        return p ? p.get('_displayname') : 'GM';
    }

    function getAttr(characterId, name) {
        var attr = findObjs({ type: 'attribute', characterid: characterId, name: name })[0];
        return attr ? attr.get('current') : '';
    }

    function setAttr(characterId, name, value) {
        var attr = findObjs({ type: 'attribute', characterid: characterId, name: name })[0];
        var moraleAttr;

        if (attr) attr.set('current', value);
        else createObj('attribute', { characterid: characterId, name: name, current: value });

        if (name === ATTR.LOYALTY_CURRENT) {
            moraleAttr = findObjs({ type: 'attribute', characterid: characterId, name: CONFIG.sheetAttrs.moraleBase })[0];
            if (moraleAttr) moraleAttr.set('current', value);
            else createObj('attribute', { characterid: characterId, name: CONFIG.sheetAttrs.moraleBase, current: value });
        }
    }

    function getNumAttr(characterId, name, fallback) {
        var v = parseFloat(getAttr(characterId, name));
        return _.isFinite(v) ? v : (fallback || 0);
    }

    function buildAttrIndex() {
        var attrs = findObjs({ type: 'attribute' }) || [];
        var idx = {};
        _.each(attrs, function (a) {
            var cid = a.get('characterid');
            var name = a.get('name');
            if (!cid || !name) return;
            if (!idx[cid]) idx[cid] = {};
            if (typeof idx[cid][name] === 'undefined') idx[cid][name] = a.get('current');
        });
        return idx;
    }

    function indexedAttr(attrIndex, characterId, name) {
        if (attrIndex && attrIndex[characterId] && typeof attrIndex[characterId][name] !== 'undefined') {
            return attrIndex[characterId][name];
        }
        return '';
    }

    function firstSelectedToken(msg) {
        if (!msg.selected || !msg.selected.length) return null;
        return getObj('graphic', msg.selected[0]._id);
    }

    function characterFromToken(token) {
        if (!token) return null;
        var charId = token.get('represents');
        return charId ? getObj('character', charId) : null;
    }

    function getCharacterByRef(ref) {
        if (!ref) return null;
        var byId = getObj('character', ref);
        if (byId) return byId;
        return _.find(findObjs({ type: 'character' }) || [], function (c) {
            return String(c.get('name') || '').toLowerCase() === String(ref).toLowerCase();
        }) || null;
    }

    function getRetainerByRef(msg, args) {
        var ref = (args && (args.id || args.retainer || args.character || args.charid)) || '';
        var retainer = null;

        if (ref) retainer = getCharacterByRef(ref);
        if (!retainer) retainer = getSelectedCharacter(msg);
        if (!retainer) return null;
        if (getAttr(retainer.id, ATTR.RETAINER_TYPE) === '') return null;
        return retainer;
    }

    function requireRetainerManage(msg, retainer) {
        var employerId, employer, employerPlayerId;

        if (!retainer) {
            send('No retainer was found. Use --id|<retainer id or name> or select a retainer token.', msg.who, msg.playerid);
            return false;
        }

        if (playerIsGM(msg.playerid)) return true;

        employerId = getAttr(retainer.id, ATTR.EMPLOYER_ID);
        employerPlayerId = getAttr(retainer.id, ATTR.EMPLOYER_PLAYER_ID);
        employer = employerId ? getCharacterByRef(employerId) : null;

        if (employerPlayerId === msg.playerid) return true;
        if (employer && canPlayerControlCharacter(msg.playerid, employer)) return true;
        if (canPlayerControlCharacter(msg.playerid, retainer)) return true;

        send('You do not control retainer ' + esc(retainer.get('name') || 'Unnamed Retainer') + '.', msg.who, msg.playerid);
        return false;
    }

    function getSelectedCharacter(msg) {
        return characterFromToken(firstSelectedToken(msg));
    }

    function getEmployerCharacter(msg, args) {
        if (args.employer || args.pc || args.pcid) return getCharacterByRef(args.employer || args.pc || args.pcid);
        return getSelectedCharacter(msg);
    }

    function getTargetCharacter(msg, args) {
        if (args.target || args.targetid || args.npc) return getCharacterByRef(args.target || args.targetid || args.npc);
        return getSelectedCharacter(msg);
    }

    function canPlayerControlCharacter(playerid, character) {
        if (!character) return false;
        if (playerIsGM(playerid)) return true;
        var controlled = splitControlledBy(character.get('controlledby'));
        return _.contains(controlled, 'all') || _.contains(controlled, playerid);
    }

    function requireControl(msg, character, label) {
        if (!character) {
            send('No ' + (label || 'character') + ' was found.', msg.who, msg.playerid);
            return false;
        }
        if (!canPlayerControlCharacter(msg.playerid, character)) {
            send('You do not control ' + esc(character.get('name')) + '.', msg.who, msg.playerid);
            return false;
        }
        return true;
    }

    function getPCLevel(character) {
        return parseIntSafe(getAttr(character.id, CONFIG.sheetAttrs.level), 1) || 1;
    }

    function getPCReactionAdj(character, args) {
        if (args && args.chaadj !== undefined) return parseIntSafe(args.chaadj, 0) || 0;
        var reactionAttr = parseIntSafe(getAttr(character.id, CONFIG.sheetAttrs.reactionBonus), NaN);
        var cha;
        if (_.isFinite(reactionAttr)) return reactionAttr;
        cha = parseIntSafe(getAttr(character.id, CONFIG.sheetAttrs.charisma), 10);
        return CONFIG.charismaReactionMap[cha] || 0;
    }

    function getReactionBonusPct(character) {
        if (!character) return 0;
        return parseIntSafe(getAttr(character.id, CONFIG.sheetAttrs.reactionBonus), 0) || 0;
    }

    function getPCLoyaltyAdj(character, args) {
        if (args && args.loyaltyadj !== undefined) return parseIntSafe(args.loyaltyadj, 0) || 0;
        var loyaltyAttr = parseIntSafe(getAttr(character.id, CONFIG.sheetAttrs.loyaltyBonus), NaN);
        if (_.isFinite(loyaltyAttr)) return loyaltyAttr;
        return 0;
    }

    function getMaximumHenchmen(character) {
        return parseIntSafe(getAttr(character.id, CONFIG.sheetAttrs.maximumHenchmen), 0) || 0;
    }

    function determineCandidateLevel(pcLevel) {
        pcLevel = parseIntSafe(pcLevel, 1) || 1;
        var roll = pctRoll();

        if (pcLevel > 11) {
            if (roll <= 25) return 3;
            if (roll <= 50) return 2;
            return 1;
        }
        if (pcLevel > 6) return roll <= 10 ? 2 : 1;
        return 1;
    }

    function weightedPick(entries, roll) {
        var n = roll || pctRoll();
        var i;
        for (i = 0; i < entries.length; i++) {
            if (n <= entries[i].max) return entries[i].value;
        }
        return entries[entries.length - 1].value;
    }

    function determineClass() {
        var base = weightedPick(CONFIG.classDistribution);

        switch (base) {
            case 'Cleric': return weightedPick(CONFIG.clericSubclasses, pctRoll());
            case 'Fighter': return weightedPick(CONFIG.fighterSubclasses, pctRoll());
            case 'Magic-User': return weightedPick(CONFIG.magicUserSubclasses, pctRoll());
            case 'Thief': return weightedPick(CONFIG.thiefSubclasses, pctRoll());
            default: return base;
        }
    }

    function normalizeRaceDistribution(dist) {
        if (!dist.length) return [{ race: 'Human', max: 100 }];

        var total = _.reduce(dist, function (m, e) { return m + e.pct; }, 0);
        var running = 0;
        if (!total) return [{ race: 'Human', max: 100 }];

        return _.map(dist, function (e, idx) {
            running += (e.pct / total) * 100;
            return { race: e.race, max: idx === dist.length - 1 ? 100 : running };
        });
    }

    function pickRace(raceBands) {
        var roll = pctRoll();
        var i;
        for (i = 0; i < raceBands.length; i++) {
            if (roll <= raceBands[i].max) return raceBands[i].race;
        }
        return raceBands[raceBands.length - 1].race;
    }

    function makeName() {
        var first = ['Al', 'Bel', 'Cor', 'Dar', 'Ela', 'Fen', 'Gar', 'Hel', 'Ivo', 'Jar', 'Kel', 'Lys', 'Mor', 'Ner', 'Or', 'Per', 'Quin', 'Rav', 'Sel', 'Tor', 'Ul', 'Var', 'Wes', 'Yor', 'Zan'];
        var second = ['adin', 'bar', 'cis', 'deth', 'en', 'fara', 'grim', 'hal', 'ian', 'jor', 'kas', 'lor', 'mond', 'nor', 'or', 'prus', 'quil', 'ric', 'sen', 'tor', 'us', 'vor', 'wen', 'yor', 'zir'];
        return first[randomInt(0, first.length - 1)] + second[randomInt(0, second.length - 1)];
    }

    function randomNameQuery(label) {
        return '?{' + (label || 'Name') + '|' + makeName() + '}';
    }

    function randomDelayReason() {
        var reasons = [
            'Thinking about the offer.',
            'Needs to check with family first.',
            'Has some business to settle before leaving.',
            'Not keen on getting killed.',
            'Wants to finish current work first.',
            'Needs time to gather equipment.',
            'Promised to see a matter through locally.',
            'Wants to hear more about the party\'s reputation.',
            'Needs to collect a debt owed to them.',
