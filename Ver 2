    function completeContractExtension(msg, employer, retainer, days, bonusPct) {
        var retainerType = getAttr(retainer.id, ATTR.RETAINER_TYPE) || 'hireling';
        var wages = {
            dailySp: getNumAttr(retainer.id, ATTR.DAILY_WAGE_SP, 0),
            monthlyGp: getNumAttr(retainer.id, ATTR.MONTHLY_WAGE_GP, 0),
            source: getAttr(retainer.id, ATTR.WAGE_SOURCE) || 'custom',
            label: getAttr(retainer.id, ATTR.RETAINER_SUBTYPE) || ''
        };
        var reactionPct = employer ? getReactionBonusPct(employer) : 0;
        var successCap = standardEmploymentSuccessCap(retainerType);
        var roll = randomInt(1, 100);
        var accepted;
        var contractGp = cpToGp(contractBaseCp(retainerType, wages, days));
        var body;
        var baseChancePct;
        var finalChancePct;
        var bonusCp = 0;
        var bonusText = '';
        var paymentResult;
        var isStandard = _.contains(['hireling', 'expert'], normalizeText(retainerType));

        bonusPct = clamp(parseIntSafe(bonusPct, getNumAttr(retainer.id, ATTR.HIRE_BONUS_PCT, 0)) || 0, 0, 100);

        if (isStandard) {
            baseChancePct = days > 7 ? basePercentFromBonusPct(bonusPct) : successCap;
            finalChancePct = days > 7 ? clamp(baseChancePct + reactionPct, 0, successCap) : successCap;
            bonusCp = standardUpfrontBonusCp(wages, bonusPct, days);
            bonusText = days <= 7 ? 'No upfront bonus required for 7 days or fewer.' : (bonusPct + '% of monthly rate');
        } else {
            baseChancePct = clamp(getNumAttr(retainer.id, ATTR.LOYALTY_CURRENT, 50), 0, successCap);
            finalChancePct = clamp(baseChancePct + reactionPct, 0, successCap);
        }

        accepted = roll <= finalChancePct;

        if (!accepted) {
            body = line('Employer', esc(employer.get('name'))) +
                line('Retainer', esc(retainer.get('name'))) +
                line('Days requested', days) +
                (isStandard ? line('Upfront bonus', bonusText + (bonusCp > 0 ? ' = ' + formatCpAsCoins(bonusCp) : ' = none')) : '') +
                line('Base chance', baseChancePct + '%') +
                line('Reaction modifier', (reactionPct >= 0 ? '+' : '') + reactionPct + '%') +
                line('Final chance', finalChancePct + '%') +
                line('Die roll', roll) +
                line('Result', '<span style="color:#ff6666;font-weight:bold;">Declined extension</span>');
            send(box('Contract Extension', body), msg.who, msg.playerid);
            return;
        }

        if (isStandard && bonusCp > 0) {
            paymentResult = deductCoins(employer, bonusCp);
            if (!paymentResult.ok) {
                body = line('Employer', esc(employer.get('name'))) +
                    line('Retainer', esc(retainer.get('name'))) +
                    line('Required upfront bonus', formatCpAsCoins(bonusCp)) +
                    line('Current coins', formatCoinBundle(paymentResult.before)) +
                    line('Result', '<span style="color:#ff6666;font-weight:bold;">Not enough coin on the employer sheet.</span>');
                send(box('Contract Extension Failed', body), msg.who, msg.playerid);
                return;
            }
        }

        setAttr(retainer.id, ATTR.CONTRACT_DAYS, days);
        if (isStandard) setAttr(retainer.id, ATTR.HIRE_BONUS_PCT, bonusPct);
        setAttr(retainer.id, ATTR.CONTRACT_PAY_GP, formatNumber2(contractGp));
        setAttr(retainer.id, ATTR.STATUS, 'active');

        body = line('Employer', esc(employer.get('name'))) +
            line('Retainer', esc(retainer.get('name'))) +
            line('Days extended', days) +
            line('Contract pay due', contractGp > 0 ? formatCpAsCoins(gpToCp(contractGp)) : 'none set') +
            (isStandard ? line('Upfront bonus', bonusText + (bonusCp > 0 ? ' = ' + formatCpAsCoins(bonusCp) : ' = none')) : '') +
            line('Base chance', baseChancePct + '%') +
