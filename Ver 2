        if (population > 8000) return randomInt(2, 20);
        return randomInt(1, 10);
    }

    function buildHireBonusQuery(employer, retainerType) {
        var reactionPct = employer ? getReactionBonusPct(employer) : 0;
        var title = 'Upfront bonus requirement for jobs over 7 days';
        var levels = bonusLevels();
        var successCap = standardEmploymentSuccessCap(retainerType);
        var seen = {};
        var options = [];

        if (employer) {
            title += ' (Reaction mod ' + (reactionPct >= 0 ? '+' : '') + reactionPct + '% included';
        } else {
            title += ' (base success only; reaction mod added when rolled';
        }

        if (successCap < 100) {
            title += ', capped at ' + successCap + '%';
        }

        title += ')';

        _.each(levels, function (pct) {
            var base = basePercentFromBonusPct(pct);
            var finalChance = employer ? clamp(base + reactionPct, 0, successCap) : clamp(base, 0, successCap);
            var key = String(finalChance);
            var label;

            if (seen[key]) return;
            seen[key] = true;

            label = pct + '% upfront bonus = ' + finalChance + '% success';
            if (finalChance >= successCap) label += ' (max useful)';
            options.push(label + ',' + pct);
        });

        return '?{' + title + '|' + options.join('|') + '}';
    }

