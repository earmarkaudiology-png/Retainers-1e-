            (args.race !== undefined && args.race !== '' ? line('Race', esc(args.race)) : '') +
            (args.npclevel !== undefined && args.npclevel !== '' ? line('Level', parseIntSafe(args.npclevel, 1) || 1) : '') +
            line('Type', esc(type) + (subtype ? ' (' + esc(subtype) + ')' : '')) +
            line('Days of service', days) +
            line('Reaction modifier', (reactionPct >= 0 ? '+' : '') + reactionPct + '%') +
            line('Maximum success chance', successCap + '%') +
            line('Offer reply delay', (normalizeText(type) === 'henchman' ? '2-8 days' : '0-4 days') + ', rolled when Make Offer is clicked') +
            line('Pro-rated pay due later', formatCpAsCoins(contractBaseCp(type, wages, days))) +
            line('Rule used', days > 7 ? 'Only the bonus is paid up front. Contracts over 7 days require an upfront bonus.' : 'No upfront bonus is required for 7 days or fewer.') +
            '<div style="margin-top:8px;">' +
            menuBtn('Make Offer', command, CONFIG.sectionColors.add.bg, CONFIG.sectionColors.add.border, 120) +
            '</div>'
        ), msg.who, msg.playerid);
    }

    function handleStandardEmploymentAdd(msg, employer, args, wages, sharePct, shareCategory, loyaltyBase, employerPlayerId) {
        var name = args.name || makeName();
        var retainerType = args.type || 'hireling';
        var subType = args.subtype || '';
        var days = Math.max(1, parseIntSafe(args.days, 7) || 7);
        var bonusPct = clamp(parseIntSafe(args.bonuspct, 0) || 0, 0, 100);
        var baseCp = contractBaseCp(retainerType, wages, days);
        var bonusCp = standardUpfrontBonusCp(wages, bonusPct, days);
        var reactionPct = getReactionBonusPct(employer);
        var successCap = standardEmploymentSuccessCap(retainerType);
        var baseChancePct = days > 7 ? basePercentFromBonusPct(bonusPct) : successCap;
        var finalChancePct = days > 7 ? clamp(baseChancePct + reactionPct, 0, successCap) : successCap;
        var roll = randomInt(1, 100);
        var accepted = roll <= finalChancePct;
        var payPeriod = 'daily prorated';
        var paymentResult;
        var retainer;
        var body;
        var assignmentText = (args.assignment ? args.assignment + ' | ' : '') + 'Contract: ' + days + ' day(s)';
        var bonusText = days <= 7 ? 'No bonus for 7 days or fewer.' : (bonusPct + '% of monthly rate');
        var delayDays = Math.max(0, parseIntSafe(args.delaydays, 0) || 0);
        var pending;

        if (delayDays > 0) {
            pending = createPendingOffer(employer, name, {
                level: parseIntSafe(args.npclevel, 1) || 1,
                className: '',
                race: args.race || ''
            }, {
                pendingMode: 'standard',
                standardArgs: _.extend({}, args, { delaydays: 0 }),
                standardWages: { dailySp: wages.dailySp, monthlyGp: wages.monthlyGp, source: wages.source, label: wages.label || subType },
                standardSharePct: sharePct,
                standardShareCategoryKey: shareCategory.key,
                standardLoyaltyBase: loyaltyBase,
                playerid: employerPlayerId
            }, delayDays, randomDelayReason(), employerPlayerId);

            body = '' +
                line('Employer', esc(employer.get('name'))) +
                line('Retainer', esc(name)) +
                line('Type', esc(retainerType) + (subType ? ' (' + esc(subType) + ')' : '')) +
                line('Reply delay', delayDays + ' day(s)') +
                line('Pending ID', esc(pending.id)) +
                line('Pro-rated pay due later', formatCpAsCoins(baseCp)) +
                line('Upfront bonus', bonusText + (bonusCp > 0 ? ' = ' + formatCpAsCoins(bonusCp) : ' = none'));
            send(box('Standard Hireling Offer Delayed', body), msg.who, msg.playerid);
            return;
        }

        if (!accepted) {
            body = '' +
                line('Employer', esc(employer.get('name'))) +
                line('Retainer', esc(name)) +
                line('Type', esc(retainerType) + (subType ? ' (' + esc(subType) + ')' : '')) +
                line('Days', days) +
                line('Pay basis', esc(payPeriod)) +
                line('Pro-rated pay due later', formatCpAsCoins(baseCp)) +
                line('Upfront bonus', bonusText + (bonusCp > 0 ? ' = ' + formatCpAsCoins(bonusCp) : ' = none')) +
                line('Base chance', baseChancePct + '%') +
                line('Reaction modifier', (reactionPct >= 0 ? '+' : '') + reactionPct + '%') +
                line('Final chance', finalChancePct + '%') +
                line('Success / failure note', 'Failure on 1d100 roll above ' + finalChancePct) +
                line('Die roll', roll) +
                line('Result', '<span style="color:#ff6666;font-weight:bold;">Declined</span>');
            if (args.pendingid && state[STATE].pendingOffers[args.pendingid]) delete state[STATE].pendingOffers[args.pendingid];
            send(box('Standard Hireling Employment', body), msg.who, msg.playerid);
            return;
        }

        paymentResult = deductCoins(employer, bonusCp);
        if (!paymentResult.ok) {
            body = '' +
                line('Employer', esc(employer.get('name'))) +
                line('Retainer', esc(name)) +
                line('Required upfront bonus', formatCpAsCoins(bonusCp)) +
                line('Current coins', formatCoinBundle(paymentResult.before)) +
                '<div style="color:#ff6666;font-weight:bold;margin-top:6px;">Not enough coin on the employer sheet.</div>';
            send(box('Standard Hireling Employment Failed', body), msg.who, msg.playerid);
            return;
        }

        retainer = buildRetainerSheet({
            name: name,
            employer: employer,
            playerid: employerPlayerId,
            controlledby: employerPlayerId,
            retainerType: retainerType,
            subType: subType,
            hireMethod: 'standard_employment',
            status: 'active',
            xpMode: defaultXpModeForType(retainerType),
            dailyWageSp: wages.dailySp,
            monthlyWageGp: wages.monthlyGp,
            wageSource: wages.source,
            initialPayment: formatNumber2(cpToGp(bonusCp)),
            sharePct: sharePct,
            shareCategory: shareCategory,
            magicDivision: args.magicdivision || '',
            quartersSupport: parseBool(args.quarters, true),
            equipment: args.equipment || '',
            magicItems: parseIntSafe(args.magicitems, 0) || 0,
            assignment: assignmentText,
            loyaltyBase: loyaltyBase,
            loyaltyCurrent: parseIntSafe(args.loyalty, loyaltyBase) || loyaltyBase,
            loyaltyNotes: args.loyaltynotes || '',
            dmMod: parseIntSafe(args.dmmod, 0) || 0,
            dmReason: args.dmreason || '',
            offerNotes: args.notes || '',
            npcLevel: parseIntSafe(args.npclevel, 1) || 1,
            className: args.classname || '',
            race: args.race || '',
            contractDays: days,
            payPeriod: payPeriod,
            hireBonusPct: bonusPct,
            contractPayGp: formatNumber2(cpToGp(baseCp))
        });

        body = '' +
            line('Employer', esc(employer.get('name'))) +
            line('Retainer', esc(retainer.get('name'))) +
            line('Type', esc(retainerType) + (subType ? ' (' + esc(subType) + ')' : '')) +
            line('Days', days) +
            line('Pay basis', esc(payPeriod)) +
            line('Pro-rated pay due later', formatCpAsCoins(baseCp)) +
            line('Upfront bonus', bonusText + (bonusCp > 0 ? ' = ' + formatCpAsCoins(bonusCp) : ' = none')) +
            line('Base chance', baseChancePct + '%') +
            line('Reaction modifier', (reactionPct >= 0 ? '+' : '') + reactionPct + '%') +
            line('Final chance', finalChancePct + '%') +
            line('Success / failure note', 'Success on ' + finalChancePct + ' or less on 1d100') +
            line('Die roll', roll) +
            line('Coins before', formatCoinBundle(paymentResult.before)) +
            line('Coins after', formatCoinBundle(paymentResult.after)) +
            line('Result', '<span style="color:#66ff66;font-weight:bold;">Accepted</span>');

        if (args.pendingid && state[STATE].pendingOffers[args.pendingid]) delete state[STATE].pendingOffers[args.pendingid];
        send(box('Standard Hireling Employment', body), msg.who, msg.playerid);
    }

    function handleAdd(msg, args) {
        var employer = getEmployerCharacter(msg, args);
        var name, sharePct, shareCategory, wages, loyaltyBase, employerPlayerId, retainer, sourceData, opts;

        if (!requireControl(msg, employer, 'employer character')) return;

        name = args.name || makeName();

        sharePct = Math.max(0, parseNumber(args.share, 0));
        shareCategory = getShareCategory(args, sharePct);
        wages = resolveWage(args.subtype || '', args);
        loyaltyBase = 50 + getPCLoyaltyAdj(employer, args);
        employerPlayerId = getEmployerPlayerId(employer, msg.playerid);

        if (isStandardEmploymentType(args.type || 'hireling')) {
            handleStandardEmploymentAdd(msg, employer, args, wages, sharePct, shareCategory, loyaltyBase, employerPlayerId);
            return;
        }

        if (normalizeText(args.type || '') === 'henchman' && parseBool(args.directoffer, false)) {
            sourceData = {
                level: parseIntSafe(args.npclevel, 1) || 1,
                className: args.classname || args.subtype || '',
                race: args.race || ''
            };
            opts = buildOfferOptions(msg, employer, args, sourceData, 'henchman', args.subtype || '', 'direct_manual');
            opts.delayDays = rollOfferDelayDays('henchman');
            if (!opts.dmReason) opts.dmReason = randomDelayReason();
            finalizeRetainerFromOffer(msg, employer, name, sourceData, opts);
            return;
        }

        retainer = buildRetainerSheet({
            name: name,
            employer: employer,
            playerid: employerPlayerId,
            controlledby: employerPlayerId,
            retainerType: args.type || 'hireling',
            subType: args.subtype || '',
            hireMethod: args.method || 'contract',
            status: args.status || 'active',
            xpMode: args.xpmode || defaultXpModeForType(args.type || 'hireling'),
            dailyWageSp: wages.dailySp,
            monthlyWageGp: wages.monthlyGp,
            wageSource: wages.source,
            initialPayment: parseMoney(args.initial, 0),
            sharePct: sharePct,
            shareCategory: shareCategory,
            magicDivision: args.magicdivision || '',
            quartersSupport: parseBool(args.quarters, true),
            equipment: args.equipment || '',
            magicItems: parseIntSafe(args.magicitems, 0) || 0,
            assignment: args.assignment || '',
            loyaltyBase: loyaltyBase,
            loyaltyCurrent: parseIntSafe(args.loyalty, loyaltyBase) || loyaltyBase,
            loyaltyNotes: args.loyaltynotes || '',
            dmMod: parseIntSafe(args.dmmod, 0) || 0,
            dmReason: args.dmreason || '',
            offerNotes: args.notes || '',
            npcLevel: parseIntSafe(args.npclevel, 1) || 1,
            className: args.classname || '',
            race: args.race || '',
            contractDays: parseIntSafe(args.days, 0) || 0,
            payPeriod: args.payperiod || '',
            hireBonusPct: parseIntSafe(args.bonuspct, 0) || 0,
            contractPayGp: parseMoney(args.contractpaygp, 0)
        });

        send(box('Retainer Added',
            line('Created', esc(retainer.get('name'))) +
            line('Employer', esc(employer.get('name'))) +
            line('Type', esc(getAttr(retainer.id, ATTR.RETAINER_TYPE))) +
            line('Subtype', esc(getAttr(retainer.id, ATTR.RETAINER_SUBTYPE))) +
            line('Wage', esc(formatWage(getAttr(retainer.id, ATTR.DAILY_WAGE_SP), getAttr(retainer.id, ATTR.MONTHLY_WAGE_GP)))) +
            line('Share', esc(getAttr(retainer.id, ATTR.TREASURE_SHARE_PCT)) + '%') +
            line('Loyalty', esc(getAttr(retainer.id, ATTR.LOYALTY_CURRENT))) +
            line('Controller', esc(getDisplayName(employerPlayerId))) +
            line('XP mode', esc(getAttr(retainer.id, ATTR.RETAINER_XP_MODE)))
        ), msg.who, msg.playerid);
    }

    function handlePending(msg, args) {
        var pending = getVisiblePendingOffers(msg);
        var employer;

        if (args.pc || args.employer) {
            employer = getCharacterByRef(args.pc || args.employer);
            if (!employer) {
                send('Employer not found.', msg.who, msg.playerid);
                return;
            }
            pending = _.filter(pending, function (p) { return p.employerId === employer.id; });
        }

        if (!pending.length) {
            send(box('Pending Retainer Offers', 'No pending offers found.'), msg.who, msg.playerid);
            return;
        }

        send(box('Pending Retainer Offers', '<div style="margin-bottom:6px;color:#ccc;">Offers with a reply delay appear here. Hirelings/experts: 0-4 days. Henchmen: 2-8 days.</div><ul style="margin:4px 0 0 18px;">' + _.map(pending, renderPendingEntry).join('') + '</ul>'), msg.who, msg.playerid);
    }

    function handleResolve(msg, args) {
        var pendingId = args.offer || args.pending || args.id;
        var pending = state[STATE].pendingOffers[pendingId];
        var employer;
        var pendingArgs;
        var pendingWages;

        if (!pending) {
            send('Pending offer ' + esc(pendingId) + ' was not found.', msg.who, msg.playerid);
            return;
        }

        employer = getCharacterByRef(pending.employerId);
        if (!requireControl(msg, employer, 'employer character')) return;

        if (args.dmmod !== undefined) pending.opts.dmMod = parseIntSafe(args.dmmod, 0) || 0;
        if (args.dmreason !== undefined) pending.opts.dmReason = args.dmreason || '';

        if (normalizeText(pending.opts.pendingMode || '') === 'standard') {
            pendingArgs = _.extend({}, pending.opts.standardArgs || {});
            pendingArgs.pendingid = pending.id;
            pendingArgs.delaydays = 0;
            pendingWages = pending.opts.standardWages || resolveWage(pendingArgs.subtype || '', pendingArgs);

            handleStandardEmploymentAdd(
                msg,
                employer,
                pendingArgs,
                pendingWages,
                parseNumber(pending.opts.standardSharePct, 0),
                getShareCategory({ sharecat: pending.opts.standardShareCategoryKey }, parseNumber(pending.opts.standardSharePct, 0)),
                parseIntSafe(pending.opts.standardLoyaltyBase, 50) || 50,
                pending.opts.playerid || getEmployerPlayerId(employer, msg.playerid)
            );
            return;
        }

        if (normalizeText(pending.opts.pendingMode || '') === 'extend') {
            handleExtendContract(msg, { id: pending.opts.retainerId, days: pending.opts.days, bonuspct: pending.opts.bonuspct, pendingid: pending.id });
            return;
        }

        pending.opts.pendingId = pending.id;
        pending.opts.delayDays = 0;
        pending.opts.override = '';
        finalizeRetainerFromOffer(msg, employer, pending.sourceName, pending.sourceData, pending.opts);
    }

    function handleModify(msg, args) {
        var retainer = getRetainerByRef(msg, args);
        var newEmployer, newEmployerPlayerId, sharePct, shareCategory, subtype, wages, cur;

        if (!requireRetainerManage(msg, retainer)) return;

        if (args.pc || args.employer) {
            newEmployer = getCharacterByRef(args.pc || args.employer);
            if (!requireControl(msg, newEmployer, 'new employer character')) return;
            newEmployerPlayerId = getEmployerPlayerId(newEmployer, msg.playerid);
            retainer.set({ controlledby: newEmployerPlayerId, inplayerjournals: 'all' });
            setAttr(retainer.id, ATTR.EMPLOYER_ID, newEmployer.id);
            setAttr(retainer.id, ATTR.EMPLOYER_NAME, newEmployer.get('name'));
            setAttr(retainer.id, ATTR.EMPLOYER_PLAYER_ID, newEmployerPlayerId);
        }

        if (args.type !== undefined) setAttr(retainer.id, ATTR.RETAINER_TYPE, args.type);
        if (args.subtype !== undefined) setAttr(retainer.id, ATTR.RETAINER_SUBTYPE, args.subtype);
        if (args.xpmode !== undefined) setAttr(retainer.id, ATTR.RETAINER_XP_MODE, args.xpmode);
        else if (args.type !== undefined) setAttr(retainer.id, ATTR.RETAINER_XP_MODE, defaultXpModeForType(args.type));
        if (args.status !== undefined) setAttr(retainer.id, ATTR.STATUS, args.status);
        if (args.assignment !== undefined) setAttr(retainer.id, ATTR.ASSIGNMENT, args.assignment);
        if (args.initial !== undefined) setAttr(retainer.id, ATTR.INITIAL_PAYMENT, parseMoney(args.initial, 0));
        if (args.notes !== undefined) setAttr(retainer.id, ATTR.OFFER_NOTES, args.notes);
        if (args.loyaltynotes !== undefined) setAttr(retainer.id, ATTR.LOYALTY_NOTES, args.loyaltynotes);
        if (args.loyalty !== undefined) setAttr(retainer.id, ATTR.LOYALTY_CURRENT, parseIntSafe(args.loyalty, getNumAttr(retainer.id, ATTR.LOYALTY_CURRENT, 50)));
        if (args.contractdays !== undefined) setAttr(retainer.id, ATTR.CONTRACT_DAYS, parseIntSafe(args.contractdays, getNumAttr(retainer.id, ATTR.CONTRACT_DAYS, 0)));
        if (args.payperiod !== undefined) setAttr(retainer.id, ATTR.PAY_PERIOD, args.payperiod);
        if (args.bonuspct !== undefined) setAttr(retainer.id, ATTR.HIRE_BONUS_PCT, parseIntSafe(args.bonuspct, getNumAttr(retainer.id, ATTR.HIRE_BONUS_PCT, 0)));
        if (args.contractpaygp !== undefined) setAttr(retainer.id, ATTR.CONTRACT_PAY_GP, parseMoney(args.contractpaygp, getNumAttr(retainer.id, ATTR.CONTRACT_PAY_GP, 0)));

        if (args.loyaltymod !== undefined) {
            cur = getNumAttr(retainer.id, ATTR.LOYALTY_CURRENT, 50);
            setAttr(retainer.id, ATTR.LOYALTY_CURRENT, cur + (parseIntSafe(args.loyaltymod, 0) || 0));
        }

        if (args.loyaltybase !== undefined) {
            setAttr(retainer.id, ATTR.LOYALTY_BASE, parseIntSafe(args.loyaltybase, getNumAttr(retainer.id, ATTR.LOYALTY_BASE, 50)));
        }

        if (args.share !== undefined || args.sharecat !== undefined || args.sharecategory !== undefined) {
            sharePct = args.share !== undefined ? Math.max(0, parseNumber(args.share, 0)) : getNumAttr(retainer.id, ATTR.TREASURE_SHARE_PCT, 0);
            shareCategory = getShareCategory(args, sharePct);
            setAttr(retainer.id, ATTR.TREASURE_SHARE_PCT, sharePct);
            setAttr(retainer.id, ATTR.SHARE_CATEGORY, shareCategory.key);
        }

        if (args.dailysp !== undefined || args.monthlygp !== undefined || args.wage !== undefined || args.subtype !== undefined || args.wagesource !== undefined || args.wagepct !== undefined) {
            subtype = args.subtype !== undefined ? args.subtype : getAttr(retainer.id, ATTR.RETAINER_SUBTYPE);

            if (args.dailysp !== undefined || args.monthlygp !== undefined || args.wage !== undefined || args.subtype !== undefined || args.wagesource !== undefined) {
                wages = resolveWage(subtype, {
                    subtype: subtype,
                    dailysp: args.dailysp,
                    monthlygp: args.monthlygp,
                    wage: args.wage,
                    wagesource: args.wagesource
                });
            } else {
                wages = {
                    dailySp: getNumAttr(retainer.id, ATTR.DAILY_WAGE_SP, 0),
                    monthlyGp: getNumAttr(retainer.id, ATTR.MONTHLY_WAGE_GP, 0),
                    source: getAttr(retainer.id, ATTR.WAGE_SOURCE) || 'custom',
                    label: subtype
                };
            }

            if (args.wagepct !== undefined) wages = applyWageAdjustmentPct(wages, args.wagepct);

            setAttr(retainer.id, ATTR.DAILY_WAGE_SP, wages.dailySp);
            setAttr(retainer.id, ATTR.MONTHLY_WAGE_GP, wages.monthlyGp);
            setAttr(retainer.id, ATTR.WAGE_SOURCE, wages.source);
        }

        send(box('Retainer Modified',
            line('Retainer', esc(retainer.get('name'))) +
            line('Employer', esc(getAttr(retainer.id, ATTR.EMPLOYER_NAME))) +
            line('Status', esc(getAttr(retainer.id, ATTR.STATUS))) +
            line('Wage', esc(formatWage(getAttr(retainer.id, ATTR.DAILY_WAGE_SP), getAttr(retainer.id, ATTR.MONTHLY_WAGE_GP)))) +
            line('Contract pay due', esc(getAttr(retainer.id, ATTR.CONTRACT_PAY_GP) || '0') + ' gp') +
            line('Share %', esc(getAttr(retainer.id, ATTR.TREASURE_SHARE_PCT)) + '%') +
            line('Loyalty', esc(getAttr(retainer.id, ATTR.LOYALTY_CURRENT)) + ' / ' + esc(getAttr(retainer.id, ATTR.LOYALTY_BASE))) +
            line('XP mode', esc(getAttr(retainer.id, ATTR.RETAINER_XP_MODE)))
        ), msg.who, msg.playerid);
    }

    function handleRemove(msg, args) {
        var retainer = getRetainerByRef(msg, args);
        var name, confirmCmd, cancelCmd;

        if (!requireRetainerManage(msg, retainer)) return;

        name = retainer.get('name') || 'Unnamed Retainer';

        if (normalizeText(args.confirm || '') !== 'yes') {
            confirmCmd = '!retainer-remove --id|' + retainer.id + ' --confirm|yes';
            cancelCmd = '!retainer-menu';

            send(box(
                'Confirm Retainer Removal',
                line('Retainer', esc(name)) +
                '<div style="margin-top:6px;color:#ff6666;font-weight:bold;">This will delete the retainer character/journal from Roll20.</div>' +
                '<div style="margin-top:8px;">' +
                    menuBtn('Confirm Delete', confirmCmd, CONFIG.sectionColors.recruit.bg, CONFIG.sectionColors.recruit.border, 110) + ' ' +
                    menuBtn('Cancel', cancelCmd, CONFIG.sectionColors.manage.bg, CONFIG.sectionColors.manage.border, 80) +
                '</div>'
            ), msg.who, msg.playerid);
            return;
        }

        retainer.remove();
        send(box('Retainer Removed', line('Removed', esc(name))), msg.who, msg.playerid);
    }

    function handleClearCandidates(msg, args) {
        var employer = args.pc || args.employer ? getCharacterByRef(args.pc || args.employer) : null;
        var candidates = _.values(state[STATE].candidates || {});
        var pending = _.values(state[STATE].pendingOffers || {});
        var count = 0;
        var pendingCount = 0;
        var removeIds;
        var removePendingIds;
        var optionEmployerIds;

        if (employer) {
            if (!requireControl(msg, employer, 'employer character')) return;
            candidates = _.filter(candidates, function (c) { return c.employerId === employer.id; });
            pending = _.filter(pending, function (p) { return p.employerId === employer.id; });
        } else if (!playerIsGM(msg.playerid)) {
            candidates = _.filter(candidates, function (c) { return c.employerPlayerId === msg.playerid; });
            pending = _.filter(pending, function (p) { return p.employerPlayerId === msg.playerid; });
        }

        optionEmployerIds = getScopeMarketOptionEmployerIds(msg, employer);

        if (!candidates.length && !optionEmployerIds.length && !pending.length) {
            send(box('Remove Candidates', 'No candidates or pending offers found to clear.'), msg.who, msg.playerid);
            return;
        }

        if (!parseBool(args.confirm, false)) {
            send(box(
                'Confirm Remove Candidates',
                line('Scope', employer ? esc(employer.get('name')) : (playerIsGM(msg.playerid) ? 'All candidates' : 'Your candidates')) +
                line('Generated candidates to remove', candidates.length) +
                line('Pending offers to remove', pending.length) +
                line('Direct hire/expert options to remove', optionEmployerIds.length) +
                '<div style="margin-top:6px;color:#ff6666;font-weight:bold;">This will permanently remove the listed candidates, pending offers, and direct market options for this scope.</div>' +
                '<div style="margin-top:8px;">' +
                    menuBtn('Confirm Remove', buildClearCandidatesCommand({ pc: employer ? employer.id : '' }) + ' --confirm|yes', CONFIG.sectionColors.recruit.bg, CONFIG.sectionColors.recruit.border, 116) + ' ' +
                    menuBtn('Cancel', '!retainer-candidates' + (employer ? ' --pc|' + employer.id : ''), CONFIG.sectionColors.manage.bg, CONFIG.sectionColors.manage.border, 76) +
                '</div>'
            ), msg.who, msg.playerid);
            return;
        }

        removeIds = _.pluck(candidates, 'id');
        _.each(removeIds, function (id) {
            if (state[STATE].candidates[id]) {
                delete state[STATE].candidates[id];
                count += 1;
            }
        });

        removePendingIds = _.pluck(pending, 'id');
        _.each(removePendingIds, function (id) {
            if (state[STATE].pendingOffers[id]) {
                delete state[STATE].pendingOffers[id];
                pendingCount += 1;
            }
        });

        _.each(optionEmployerIds, function (employerId) {
            setEmployerMarketOptions(employerId, false);
        });

        send(box('Candidates Removed',
            line('Generated candidates removed', count) +
            line('Pending offers removed', pendingCount) +
            line('Direct hire/expert option groups removed', optionEmployerIds.length) +
            line('Scope', employer ? esc(employer.get('name')) : (playerIsGM(msg.playerid) ? 'All candidates' : 'Your candidates'))
        ), msg.who, msg.playerid);
    }

    function handleDeleteCandidate(msg, args) {
        var candidateId = args.candidate || args.id;
        var candidate = state[STATE].candidates[candidateId];
        var confirmCmd, cancelCmd;

        if (!candidate) {
            send('Candidate ' + esc(candidateId) + ' was not found.', msg.who, msg.playerid);
            return;
        }

        if (!candidateDeleteAllowed(msg, candidate)) {
            send('You do not manage candidate ' + esc(candidateId) + '.', msg.who, msg.playerid);
            return;
        }

        if (normalizeText(args.confirm || '') !== 'yes') {
            confirmCmd = '!retainer-delete-candidate --candidate|' + candidate.id + ' --confirm|yes';
            cancelCmd = '!retainer-menu';

            send(box(
                'Confirm Candidate Deletion',
                line('Candidate', esc(candidate.name)) +
