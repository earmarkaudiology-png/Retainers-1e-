    function resolveWage(subType, args) {
        var key = normalizeText(subType || args.subtype || '');
        var lookup = CONFIG.wageTable[key] || null;
        var dailySp = parseNumber(args.dailysp, NaN);
        var monthlyGp = parseNumber(args.monthlygp, NaN);
        var source = 'custom';

        if (!_.isFinite(dailySp) && !_.isFinite(monthlyGp) && args.wage !== undefined && args.wage !== '') {
            monthlyGp = parseMoney(args.wage, 0);
        }

        if (!_.isFinite(dailySp) && lookup) dailySp = lookup.dailySp;
        if (!_.isFinite(monthlyGp) && lookup) monthlyGp = lookup.monthlyGp;

        if (_.isFinite(monthlyGp) && monthlyGp === 0 && lookup && lookup.monthlyGp > 0 && String(args.monthlygp) === '0') {
            monthlyGp = lookup.monthlyGp;
        }

        if (!_.isFinite(dailySp)) dailySp = 0;
        if (!_.isFinite(monthlyGp)) monthlyGp = 0;

        if (lookup && normalizeText(args.wagesource || '') !== 'custom') source = lookup.label;
        if (args.wagesource) source = args.wagesource;

        return {
            dailySp: dailySp,
            monthlyGp: monthlyGp,
            source: source,
            label: lookup ? lookup.label : (args.subtype || '')
        };
    }

    function applyWageAdjustmentPct(wages, pct) {
        var factor = 1 + (parseNumber(pct, 0) / 100);
        var dailySp = parseNumber(wages && wages.dailySp, 0);
        var monthlyGp = parseNumber(wages && wages.monthlyGp, 0);

        factor = Math.max(0, factor);

        return {
            dailySp: Math.max(0, Math.round(dailySp * factor * 100) / 100),
            monthlyGp: Math.max(0, Math.round(monthlyGp * factor * 100) / 100),
            source: wages && wages.source ? wages.source : 'custom',
            label: wages && wages.label ? wages.label : ''
        };
    }


    function defaultXpModeForType(retainerType) {
        var key = normalizeText(retainerType || '');
        if (key === 'henchman') return 'half';
        if (key === 'companion' || key === 'fullshare' || key === 'full') return 'full';
        return 'none';
    }

    function basePercentFromBonusPct(bonusPct) {
        var b = clamp(parseNumber(bonusPct, 0), 0, 100);

        if (b <= 10) return Math.round(lerp(17, 33, b / 10));
        if (b <= 15) return Math.round(lerp(33, 50, (b - 10) / 5));
        if (b <= 20) return Math.round(lerp(50, 67, (b - 15) / 5));
        if (b <= 25) return Math.round(lerp(67, 83, (b - 20) / 5));
        return Math.round(lerp(83, 100, (b - 25) / 75));
    }

    function bonusLevels() {
        var out = [];
        var i;
        for (i = 0; i <= 100; i += 5) out.push(i);
        return out;
    }

    function standardEmploymentSuccessCap(retainerType) {
