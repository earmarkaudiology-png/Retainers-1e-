            menuBtn('Henchman Mods', '!retainer-henchman-modifiers', CONFIG.sectionColors.ref.bg, CONFIG.sectionColors.ref.border, 106),
            menuBtn('Loyalty Table', '!retainer-loyalty-table', CONFIG.sectionColors.ref.bg, CONFIG.sectionColors.ref.border, 94),
            menuBtn('Loyalty Info', '!retainer-loyalty-info', CONFIG.sectionColors.ref.bg, CONFIG.sectionColors.ref.border, 90),
            menuBtn('Help', '!retainer-help', CONFIG.sectionColors.ref.bg, CONFIG.sectionColors.ref.border, 76)
        ]);

        if (playerIsGM(msg.playerid)) {
            html += menuSection('4. GM Only', [
                menuBtn('New Campaign', '!retainer-reset', CONFIG.sectionColors.recruit.bg, CONFIG.sectionColors.recruit.border, 110)
            ]);
        }

        html += '</div>';
        send(html, msg.who, msg.playerid);
    }

    function handleInput(msg) {
        if (msg.type !== 'api') return;
        if (!msg.content || msg.content.indexOf('!retainer') !== 0) return;

        var command = msg.content.split(/\s+/)[0];
        var args = parseArgs(msg.content);

        switch (command) {
            case '!retainer-menu': handleMenu(msg); break;
            case '!retainer-help': handleHelp(msg); break;
            case '!retainer-seek': handleSeek(msg, args); break;
            case '!retainer-candidates': handleCandidates(msg, args); break;
            case '!retainer-accept': handleAccept(msg, args); break;
            case '!retainer-offer': handleOffer(msg, args); break;
            case '!retainer-add-token-npc': handleAddTokenNpc(msg, args); break;
            case '!retainer-add': handleAdd(msg, args); break;
            case '!retainer-prepare-standard': handlePrepareStandard(msg, args); break;
            case '!retainer-pending': handlePending(msg, args); break;
            case '!retainer-resolve': handleResolve(msg, args); break;
            case '!retainer-wages': handleWages(msg); break;
            case '!retainer-search-costs': handleSearchCosts(msg); break;
            case '!retainer-henchman-modifiers': handleHenchmanModifiers(msg); break;
            case '!retainer-loyalty-table': handleLoyaltyTable(msg); break;
            case '!retainer-loyalty-info': handleLoyaltyInfo(msg); break;
            case '!retainer-pay-menu': handlePayMenu(msg, args); break;
            case '!retainer-pay-normal': handlePayContract(msg, args); break;
            case '!retainer-pay-contract': handlePayContract(msg, args); break;
            case '!retainer-pay-prorated': handlePayProrated(msg, args); break;
            case '!retainer-pay-share': handlePayShare(msg, args); break;
            case '!retainer-extend-contract': handleExtendContract(msg, args); break;
            case '!retainer-pay-all': handlePayAll(msg, args); break;
            case '!retainer-modify': handleModify(msg, args); break;
            case '!retainer-remove': handleRemove(msg, args); break;
            case '!retainer-delete-candidate': handleDeleteCandidate(msg, args); break;
            case '!retainer-clear-candidates': handleClearCandidates(msg, args); break;
            case '!retainer-reset': handleReset(msg, args); break;
            case '!retainer-manage': handleManageMenu(msg, args); break;
            case '!retainer-report':
            case '!retainer-my-report': handleReport(msg, args); break;
            default: handleHelp(msg); break;
        }
    }

    function checkInstall() {
        if (!state[STATE]) {
            state[STATE] = {
                version: VERSION,
                candidates: {},
                nextCandidateId: 1,
                pendingOffers: {},
                nextPendingId: 1,
                marketOptionsByEmployer: {}
            };
        } else {
            state[STATE].candidates = state[STATE].candidates || {};
            state[STATE].nextCandidateId = state[STATE].nextCandidateId || 1;
            state[STATE].pendingOffers = state[STATE].pendingOffers || {};
            state[STATE].nextPendingId = state[STATE].nextPendingId || 1;
            state[STATE].marketOptionsByEmployer = state[STATE].marketOptionsByEmployer || {};
            state[STATE].version = VERSION;
        }
        log(SCRIPT + ' v' + VERSION + ' ready.');
    }

    function registerEventHandlers() {
        on('chat:message', handleInput);
    }

    return {
        CheckInstall: checkInstall,
        RegisterEventHandlers: registerEventHandlers
    };
}());

on('ready', function () {
    'use strict';
    RetainerManager.CheckInstall();
    RetainerManager.RegisterEventHandlers();
});
