    function computeInterest(opts) {
        var initialPayment = parseMoney(opts.initialPayment, 0);
        var npcLevel = parseIntSafe(opts.npcLevel, 1) || 1;
        var baseRequired = npcLevel * 100;
        var interest = 0;
        var details = [];

        if (initialPayment >= baseRequired) {
            interest += 25;
            details.push('Initial payment meets minimum (' + baseRequired + ' gp): +25%');
            var extras = Math.floor((initialPayment - baseRequired) / 100);
            var extraBonus = Math.min(30, extras * 10);
            if (extraBonus > 0) {
                interest += extraBonus;
                details.push('Additional 100 gp increments: +' + extraBonus + '%');
            }
        } else {
            details.push('Initial payment below minimum (' + baseRequired + ' gp): +0%');
        }

        if (parseBool(opts.completeEquipment, true)) details.push('Complete equipment stated: +0% (required condition)');
        else details.push('Complete equipment not confirmed: +0%');

        if (opts.quartersSupport) {
            interest += 5;
            details.push('Quarters and support: +5%');
        } else {
            interest -= 25;
            details.push('No quarters and support: -25%');
        }

        var magicItems = parseIntSafe(opts.magicItems, 0) || 0;
        if (magicItems > 0) {
            var magicBonus = magicItems * 15;
            interest += magicBonus;
            details.push('Magic items (' + magicItems + '): +' + magicBonus + '%');
        }

        var dmMod = parseIntSafe(opts.dmMod, 0) || 0;
        if (dmMod !== 0) {
            interest += dmMod;
            details.push('DM modifier' + (opts.dmReason ? ' (' + opts.dmReason + ')' : '') + ': ' + (dmMod > 0 ? '+' : '') + dmMod + '%');
        }

        return { interest: interest, details: details, shareCategory: opts.shareCategory };
    }

