        var monthlyGp = parseMoney(getAttr(retainer.id, ATTR.MONTHLY_WAGE_GP), 0);
        var dailyCp = spToCp(dailySp);
        var monthlyCp = gpToCp(monthlyGp);
        var wageCp = 0;
        var wageBasis = 'none';
        var note = '';

        if (contractCp > 0 && payPeriodKey.indexOf('prorated') !== -1) {
            note = 'Contract pay due already covers the current prorated amount.';
        } else if (payPeriodKey.indexOf('month') !== -1 && monthlyCp > 0) {
            wageCp = monthlyCp;
            wageBasis = '1 month';
        } else if (payPeriodKey.indexOf('day') !== -1 && dailyCp > 0) {
            wageCp = dailyCp;
            wageBasis = '1 day';
        } else if (dailyCp > 0 && monthlyCp <= 0) {
            wageCp = dailyCp;
            wageBasis = '1 day';
        } else if (monthlyCp > 0) {
            wageCp = monthlyCp;
            wageBasis = '1 month';
        } else if (dailyCp > 0) {
            wageCp = dailyCp;
            wageBasis = '1 day';
        }

        return {
            payPeriod: payPeriodRaw || '',
            wageCp: wageCp,
            wageBasis: wageBasis,
            contractCp: contractCp,
            totalCp: wageCp + contractCp,
            note: note
        };
