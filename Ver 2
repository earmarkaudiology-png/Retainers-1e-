    function inferShareCategory(sharePct) {
        sharePct = Math.max(0, parseNumber(sharePct, 0));
        if (sharePct <= 0) return CONFIG.shareCategories.none;
        if (sharePct <= 5) return CONFIG.shareCategories.partial;
