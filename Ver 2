    function parseNumber(value, fallback) {
        var n = parseFloat(value);
        return _.isFinite(n) ? n : fallback;
    }

    function parseIntSafe(value, fallback) {
        var n = parseInt(value, 10);
        return _.isFinite(n) ? n : fallback;
    }

    function parseMoney(value, fallback) {
        if (value === undefined || value === null || value === '') return fallback || 0;
        return parseNumber(String(value).replace(/[^0-9.\-]/g, ''), fallback || 0);
    }

    function parseBool(value, fallback) {
        if (value === undefined || value === null || value === '') return !!fallback;
        value = String(value).toLowerCase();
        if (_.contains(['yes', 'true', '1', 'y', 'on'], value)) return true;
        if (_.contains(['no', 'false', '0', 'n', 'off'], value)) return false;
        return !!fallback;
    }

    function formatNumber2(n) {
        var s = (Math.round(n * 100) / 100).toFixed(2);
        s = s.replace(/\.00$/, '').replace(/(\.\d)0$/, '$1');
        return s;
    }

    function clamp(n, min, max) {
        return Math.max(min, Math.min(max, n));
    }

    function lerp(a, b, t) {
        return a + (b - a) * t;
    }

    function normalizeText(value) {
        return String(value || '').toLowerCase().replace(/[^a-z0-9]+/g, '');
    }

    function pctRoll() {
        return randomInteger(100);
    }

    function randomInt(min, max) {
        return randomInteger(max - min + 1) + min - 1;
    }

    function formatWage(dailySp, monthlyGp) {
        var daily = parseNumber(dailySp, 0);
        var monthly = parseNumber(monthlyGp, 0);
        var dailyText = formatNumber2(daily);
        var monthlyText = formatNumber2(monthly);

        if (daily > 0 && monthly > 0) return dailyText + ' sp/day, ' + monthlyText + ' gp/month';
        if (daily > 0) return dailyText + ' sp/day';
        if (monthly > 0) return monthlyText + ' gp/month';
        return 'special/manual';
    }

