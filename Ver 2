    function handlePayShare(msg, args) {
        var retainer = getRetainerByRef(msg, args);
        var employer;
        var bundle;
        var coinKey;
        var amount;
        var amountCp;
        var paymentResult;
        var depositResult;
        var body;

        if (!requireRetainerManage(msg, retainer)) return;

        employer = getCharacterByRef(getAttr(retainer.id, ATTR.EMPLOYER_ID));
        if (!employer) {
            send(box('Share of Treasure Failed', 'Employer not found.' + payMenuRow(retainer.id)), msg.who, msg.playerid);
            return;
        }

        if (args.coin !== undefined || args.amount !== undefined) {
            coinKey = normalizeText(args.coin || 'gp');
            if (!_.contains(['gp', 'sp', 'cp'], coinKey)) coinKey = 'gp';
            amount = Math.max(0, parseIntSafe(args.amount, 0) || 0);
            bundle = bundleFromSingleCoin(coinKey, amount);
        } else {
            bundle = {
                                gp: Math.max(0, parseIntSafe(args.gp, 0) || 0),
                sp: Math.max(0, parseIntSafe(args.sp, 0) || 0),
                cp: Math.max(0, parseIntSafe(args.cp, 0) || 0)
            };
        }
        amountCp = totalCpFromBundle(bundle);

        if (amountCp <= 0) {
            body = line('Employer', esc(employer.get('name'))) +
                line('Retainer', esc(retainer.get('name'))) +
                line('Result', 'No treasure amount was entered.');
            send(box('Share of Treasure', body + payMenuRow(retainer.id)), msg.who, msg.playerid);
            return;
        }

        paymentResult = deductCoins(employer, amountCp);
        if (!paymentResult.ok) {
            body = line('Employer', esc(employer.get('name'))) +
                line('Retainer', esc(retainer.get('name'))) +
                line('Amount needed', formatCoinBundle(bundle)) +
                line('Employer coins', formatCoinBundle(paymentResult.before)) +
                line('Result', '<span style="color:#ff6666;font-weight:bold;">Not enough coin on employer sheet.</span>');
            send(box('Share of Treasure Failed', body + payMenuRow(retainer.id)), msg.who, msg.playerid);
            return;
        }

        depositResult = addCoins(retainer, amountCp);

        body = line('Employer', esc(employer.get('name'))) +
            line('Retainer', esc(retainer.get('name'))) +
            line('Treasure share', formatCoinBundle(bundle)) +
            line('Employer before', formatCoinBundle(paymentResult.before)) +
            line('Employer after', formatCoinBundle(paymentResult.after)) +
            line('Retainer before', formatCoinBundle(depositResult.before)) +
            line('Retainer after', formatCoinBundle(depositResult.after));

        send(box('Share of Treasure Complete', body + payMenuRow(retainer.id)), msg.who, msg.playerid);
    }

    function handlePayAll(msg, args) {
        var employer = getEmployerCharacter(msg, args);
        var entries;
        var payable = [];
        var totalCp = 0;
        var paymentResult;
        var lines = [];

        if (!requireControl(msg, employer, 'employer character')) return;

        entries = _.filter(getRetainerRosterEntries(), function (e) {
            return entryAttr(e, ATTR.EMPLOYER_ID) === employer.id &&
                normalizeText(entryAttr(e, ATTR.STATUS)) === 'active';
        });

        _.each(entries, function (e) {
            var typeKey = normalizeText(entryAttr(e, ATTR.RETAINER_TYPE));
            var pay = getContractPayOnlyBreakdown(e.character);
            if (typeKey === 'npc') return;
            if (pay.totalCp <= 0) return;
            payable.push({ entry: e, pay: pay });
            totalCp += pay.totalCp;
        });

        if (!payable.length) {
            send(box('Pay All Retainers',
                line('Employer', esc(employer.get('name'))) +
                line('Result', 'No contract amounts are currently due for active paid retainers.')
            ), msg.who, msg.playerid);
            return;
        }

        if (!parseBool(args.confirm, false)) {
            send(box('Confirm Pay All Retainers',
                line('Employer', esc(employer.get('name'))) +
                line('Retainers due pay', payable.length) +
                line('Total contract amounts', formatCpAsCoins(totalCp)) +
                line('Employer coins', formatCoinBundle(getCoinBundle(employer.id))) +
                '<div style="margin-top:6px;color:#ff6666;font-weight:bold;">Are you sure you want to pay all contract amounts due for this PC?</div>' +
                '<div style="margin-top:8px;">' +
                    menuBtn('Confirm Pay All', '!retainer-pay-all --pc|' + employer.id + ' --confirm|yes', CONFIG.sectionColors.manage.bg, CONFIG.sectionColors.manage.border, 116) + ' ' +
                    menuBtn('Cancel', '!retainer-menu', CONFIG.sectionColors.manage.bg, CONFIG.sectionColors.manage.border, 80) +
                '</div>'
            ), msg.who, msg.playerid);
            return;
        }

        paymentResult = deductCoins(employer, totalCp);
        if (!paymentResult.ok) {
            send(box('Pay All Retainers Failed',
                line('Employer', esc(employer.get('name'))) +
                line('Retainers due pay', payable.length) +
                line('Amount needed', formatCpAsCoins(totalCp)) +
                line('Employer coins', formatCoinBundle(paymentResult.before)) +
                line('Result', '<span style="color:#ff6666;font-weight:bold;">Not enough coin on employer sheet.</span>')
            ), msg.who, msg.playerid);
            return;
        }

        _.each(payable, function (item) {
            var retainer = item.entry.character;
            addCoins(retainer, item.pay.totalCp);
            setAttr(retainer.id, ATTR.CONTRACT_PAY_GP, 0);
            lines.push('<li><b>' + esc(retainer.get('name')) + '</b> — ' + formatCpAsCoins(item.pay.totalCp) + '</li>');
        });

        send(box('Pay All Retainers Complete',
            line('Employer', esc(employer.get('name'))) +
            line('Total paid', formatCpAsCoins(totalCp)) +
            line('Retainers paid', payable.length) +
            line('Employer before', formatCoinBundle(paymentResult.before)) +
            line('Employer after', formatCoinBundle(paymentResult.after)) +
            '<div style="margin-top:6px;"><b>Payments</b><ul style="margin:4px 0 0 18px;">' + lines.join('') + '</ul></div>'
        ), msg.who, msg.playerid);
    }

