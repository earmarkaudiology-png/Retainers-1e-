    function handlePayContract(msg, args) {
        var retainer = getRetainerByRef(msg, args);
        var employer;
        var pay;
        var paymentResult;
        var depositResult;
        var body;

        if (!requireRetainerManage(msg, retainer)) return;

        employer = getCharacterByRef(getAttr(retainer.id, ATTR.EMPLOYER_ID));
        if (!employer) {
            send(box('Pay Contract Amount Failed', 'Employer not found.' + payMenuRow(retainer.id)), msg.who, msg.playerid);
            return;
        }

        pay = getContractPayOnlyBreakdown(retainer);

        if (pay.totalCp <= 0) {
            body = line('Employer', esc(employer.get('name'))) +
                line('Retainer', esc(retainer.get('name'))) +
                line('Result', 'No contract amount is currently due.');
            send(box('Pay Contract Amount', body + payMenuRow(retainer.id)), msg.who, msg.playerid);
            return;
        }

        paymentResult = deductCoins(employer, pay.totalCp);
        if (!paymentResult.ok) {
            body = line('Employer', esc(employer.get('name'))) +
                line('Retainer', esc(retainer.get('name'))) +
                line('Amount needed', formatCpAsCoins(pay.totalCp)) +
                line('Employer coins', formatCoinBundle(paymentResult.before)) +
                line('Result', '<span style="color:#ff6666;font-weight:bold;">Not enough coin on employer sheet.</span>');
            send(box('Pay Contract Amount Failed', body + payMenuRow(retainer.id)), msg.who, msg.playerid);
            return;
